
// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL") // ใส่ไว้ถ้าต้องใช้ Migrate ผ่านพอร์ต 5432 บน Supabase
}

model patients{
  id Int @id @default(autoincrement())
  firstName String
  middleName String 
  lastName String
  dateOfBirth DateTime
  gender String
  phone String
  email String @unique
  language String
  address String
  nationality String
  emergencyContact String
  religion String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}